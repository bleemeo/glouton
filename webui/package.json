{
  "name": "glouton-panel",
  "version": "0.0.1",
  "description": "UI for local Glouton",
  "browserslist": [
    "defaults",
    "last 5 year",
    "firefox 45"
  ],
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "build": "pnpm run clean && vite build --mode production",
    "deploy": "pnpm run build && mkdir -p ../api/assets/ && for f in $(find ./dist/assets -name '*.css'); do cat $f | gzip > ../api/assets/$(basename $f); done && for f in $(find ./dist/assets -name '*.js'); do cat $f | gzip > ../api/assets/$(basename $f); done",
    "clean": "rm -rf dist",
    "lint": "tsc -b && eslint src && echo '\nRunning typescript check...' && tsc -b && pnpm run knip && pnpm audit && pnpm run show-success",
    "show-success": "echo '\n🎉 Everything is good, no linter issue 🎉'",
    "prettify": "prettier --write 'src/'",
    "knip": "knip --tsConfig tsconfig.app.json"
  },
  "author": "Tom Darneix",
  "license": "ISC",
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
